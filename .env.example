# Copy to .env.local and fill in from Supabase Dashboard → Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key (Dashboard labels it "anon" or "publishable")
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# service_role key — server-only; never expose to the browser
SUPABASE_ADMIN_KEY=

# Password reset: add these to Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
# (local and production examples)
# http://localhost:3000/admin/login/reset-password
# https://YOUR_DOMAIN/admin/login/reset-password
